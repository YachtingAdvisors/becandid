# ============================================================
# Be Candid — Environment Variables
# Copy to apps/web/.env.local and fill in all values
# ============================================================

# ─── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Anthropic (AI conversation guides) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Model name (change to control AI guide quality/cost)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Resend (email) ──────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=Be Candid <noreply@becandid.io>

# ─── Twilio (SMS) ────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://becandid.io
CRON_SECRET=generate-a-random-string-here

# ─── Chrome Extension (CORS) ────────────────────────────────
# The published extension's stable ID (from chrome.google.com/webstore).
# Without this, extension CORS is blocked in production.
ALLOWED_EXTENSION_ID=your-extension-id-here

# ─── Encryption (generate with: openssl rand -hex 32) ────────
ENCRYPTION_MASTER_KEY=64-character-hex-string

# ─── Expo Push (optional, for enhanced delivery) ─────────────
# EXPO_ACCESS_TOKEN=...

# ─── Beta Mode ─────────────────────────────────────────────
# Set to 'true' to unlock all features for free (no paywalls).
# Remove or set to 'false' when paid plans go live.
NEXT_PUBLIC_BETA_MODE=false

# ─── Stripe (billing) ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRODUCT_PRO=prod_...
STRIPE_PRODUCT_THERAPY=prod_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_THERAPY_MONTHLY=price_...
STRIPE_PRICE_THERAPY_ANNUAL=price_...

# ─── Upstash Redis (distributed rate limiting) ────────────
# Create a free Redis database at https://console.upstash.com
# Without these, rate limiting falls back to in-memory (fine for local dev).
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# ─── Error Tracking (optional) ─────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ─── SEO & Indexing ────────────────────────────────────────
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
GA_ID=G-...

# Google Search Console site URL (for performance API)
GSC_SITE_URL=https://becandid.io

# Google Indexing API — service account credentials
GOOGLE_SERVICE_ACCOUNT_EMAIL=...@...iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Bing Webmaster Tools — URL Submission API key
# Get from: https://www.bing.com/webmasters → API Access → API key
BING_API_KEY=...

# Bing site verification token (from Bing Webmaster Tools)
BING_SITE_VERIFICATION=...
