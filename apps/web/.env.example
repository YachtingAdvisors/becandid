# ============================================================
# Be Candid — Environment Variables
# Copy to apps/web/.env.local and fill in all values
# ============================================================

# ─── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Anthropic (AI conversation guides) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Resend (email) ──────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=Be Candid <noreply@becandid.io>

# ─── Twilio (SMS) ────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://becandid.io
CRON_SECRET=generate-a-random-string-here

# ─── Encryption (generate with: openssl rand -hex 32) ────────
ENCRYPTION_MASTER_KEY=64-character-hex-string

# ─── Expo Push (optional, for enhanced delivery) ─────────────
# EXPO_ACCESS_TOKEN=...

# ─── Stripe (billing) ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# ─── Error Tracking (optional) ─────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
