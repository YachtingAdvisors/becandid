{
  "manifest_version": 3,
  "name": "Be Candid - Awareness Monitor",
  "version": "1.0.0",
  "description": "Privacy-first browsing awareness for accountability.",
  "permissions": ["tabs", "activeTab", "storage", "alarms", "webNavigation", "idle"],
  "host_permissions": ["https://becandid.io/*", "https://*.becandid.io/*", "https://*.vercel.app/*", "https://*.supabase.co/*"],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Be Candid"
  },
  "icons": {
    "16": "src/assets/icon-16.png",
    "48": "src/assets/icon-48.png",
    "128": "src/assets/icon-128.png"
  },
  "homepage_url": "https://becandid.io"
}
