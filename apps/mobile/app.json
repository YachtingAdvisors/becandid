{
  "expo": {
    "name": "Be Candid",
    "slug": "be-candid",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "becandid",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#226779",
          "sounds": []
        }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "io.becandid.app",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#226779"
      },
      "package": "io.becandid.app",
      "permissions": ["RECEIVE_BOOT_COMPLETED", "SCHEDULE_EXACT_ALARM"]
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
