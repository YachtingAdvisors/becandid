{
  "name": "be-candid",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web": "npm run --workspace=@be-candid/web dev",
    "dev": "npm run --workspace=@be-candid/web dev",
    "build": "npm run --workspace=@be-candid/web build",
    "lint": "npm run --workspace=@be-candid/web lint",
    "db:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > apps/web/types/supabase.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "app-builder-bin": "^5.0.0-alpha.10"
  }
}
