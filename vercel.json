{
  "buildCommand": "cd apps/web && npm run build",
  "outputDirectory": "apps/web/.next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    { "path": "/api/cron/checkin", "schedule": "0 * * * *" },
    { "path": "/api/cron/digest", "schedule": "0 8 * * 1" },
    { "path": "/api/cron/reengagement", "schedule": "0 10 * * *" },
    { "path": "/api/cron/patterns", "schedule": "0 */6 * * *" },
    { "path": "/api/cron/journal-reminders", "schedule": "0 8,10,12,14,16,18,20 * * *" },
    { "path": "/api/cron/weekly-reflection", "schedule": "0 19 * * 0" },
    { "path": "/api/cron/focus-segments", "schedule": "0 5,17 * * *" },
    { "path": "/api/cron/partner-impact", "schedule": "0 19 * * 0" }
  ]
}
